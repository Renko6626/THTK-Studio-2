+    def _reopen_clean(self, project, program):
+        """Drop the import/open 'Batch Processing' transaction.
+
+        ``GhidraProject.importProgram()`` / ``openProgram()`` return a program
+        with a long-lived batch transaction still open (``getCurrentTransactionInfo()``
+        is non-None, status NOT_DONE). That transaction keeps the program lock,
+        so ``DomainFile.save()`` raises ``IOException: Unable to lock due to active
+        transaction``. Persist once, release the loaded handle (which ends the
+        batch transaction), then reopen the DomainFile writable; the fresh handle
+        has no lingering transaction so later saves succeed.
+        """
+        from ghidra.util.task import TaskMonitor  # noqa: PLC0415
+
+        if program.getCurrentTransactionInfo() is None:
+            return program  # already clean
+
+        name = program.getName()
+        df = program.getDomainFile()
+        if df is None or not df.canSave():
+            # Imported (not yet on disk) -> write it into the project.
+            project.saveAs(program, "/", name, True)
+
+        # Release the loaded handle; this ends the open batch transaction.
+        project.close(program)
+
+        # Reopen the DomainFile writable (okToUpgrade=False, okToRecover=False).
+        # Consume with a dedicated java.lang.Object so close() can release exactly
+        # this handle and free the project lock. (A Python object fails JPype
+        # overload matching; the GhidraProject as consumer stays outstanding after
+        # GhidraProject.close() and blocks the next openProject -> LockException.)
+        from java.lang import Object as _JObject  # noqa: PLC0415
+
+        project_data = project.getProject().getProjectData()
+        df = project_data.getRootFolder().getFile(name)
+        consumer = _JObject()
+        self._consumer = consumer
+        return df.getDomainObject(consumer, False, False, TaskMonitor.DUMMY)
+
     def _end_open_transactions(self) -> None:
         """End any active transactions so save/undo can proceed.
 
